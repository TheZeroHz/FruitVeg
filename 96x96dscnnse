# Stem — stride 2 brings 96x96 → 48x48
x = Conv2D(16, 3, strides=2, padding='same', use_bias=False)(inputs)  # 48x48
x = BatchNormalization()(x)
x = ReLU()(x)

# -------- Texture Branch --------
# 96x96 is smaller so we use 2 stride-2 ds_blocks instead of 3
# 48x48 → 48x48 (no stride, refine features)
t = ds_block(x, 32)               # 48x48
t = se_block(t)
# 48x48 → 24x24
t = ds_block(t, 64, stride=2)     # 24x24
t = se_block(t)
# 24x24 → 12x12
t = ds_block(t, 96, stride=2)     # 12x12
# 96 filters instead of 128 — proportional to input resolution reduction

# -------- Color Branch (channel attention gate) --------
# Gates the 96-channel texture map
c = GlobalAveragePooling2D()(x)
c = Dense(24, activation='relu')(c)   # Scaled down from 32
c = Dense(96, activation='sigmoid')(c)  # Must match texture branch channels (96)
c = Reshape((1, 1, 96))(c)

# -------- Fusion --------
fused = Multiply()([t, c])

# -------- Head --------
fused = ds_block(fused, 96)
fused = se_block(fused)
fused = GlobalAveragePooling2D()(fused)
fused = Dropout(0.5)(fused)
fused = Dense(48, activation='relu')(fused)   # Scaled down from 64
