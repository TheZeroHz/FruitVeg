# -----------------------------
# Label smoothing loss
# -----------------------------
def label_smoothed_loss(y_true, y_pred, smoothing=0.1):
    n_classes = tf.cast(tf.shape(y_pred)[-1], tf.float32)
    y_true_smooth = y_true * (1.0 - smoothing) + (smoothing / n_classes)
    return tf.keras.losses.categorical_crossentropy(y_true_smooth, y_pred)

# -----------------------------
# Cosine decay schedule
# -----------------------------
def cosine_decay_schedule(epoch):
    progress = epoch / max(EPOCHS - 1, 1)
    cosine = 0.5 * (1 + math.cos(math.pi * progress))
    return float(LEARNING_RATE * cosine + 1e-7)

# -----------------------------
# Depthwise Separable Block with optional residual
# -----------------------------
def ds_block(x, filters, stride=1):
    residual = x
    out = DepthwiseConv2D(3, strides=stride, padding='same', use_bias=False)(x)
    out = BatchNormalization()(out)
    out = ReLU()(out)
    out = Conv2D(filters, 1, padding='same', use_bias=False)(out)
    out = BatchNormalization()(out)
    out = ReLU()(out)
    if stride == 1 and K.int_shape(residual)[-1] == filters:
        out = Add()([out, residual])
    return out

# -----------------------------
# Squeeze-and-Excitation block
# -----------------------------
def se_block(x, ratio=8):
    channels = K.int_shape(x)[-1]
    se = GlobalAveragePooling2D()(x)
    se = Dense(max(channels // ratio, 4), activation='relu')(se)
    se = Dense(channels, activation='sigmoid')(se)
    se = Reshape((1, 1, channels))(se)
    return Multiply()([x, se])

# -----------------------------
# AgriFreshNet-Lite v2 (96x96)
# -----------------------------
